{
  "title": "Ctrl+0 to activate Ghostty",
  "rules": [
    {
      "description": "ctrl+0 activates Ghostty",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "0",
            "modifiers": {
              "mandatory": ["control"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "shell_command": "open -a Ghostty"
            }
          ]
        }
      ]
    }
  ]
}
