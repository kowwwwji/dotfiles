{
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tmux_info=$(tmux display-message -p -t \"$TMUX_PANE\" '#S:#W' 2>/dev/null); terminal-notifier -title \"Claude Code: ${tmux_info}\" -message \" コマンド実行していいですか\" -sound default "
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tmux_info=$(tmux display-message -p -t \"$TMUX_PANE\" '#S:#W' 2>/dev/null); terminal-notifier -title \"Claude Code: ${tmux_info}\" -message '終わったよ' -sound default; tty=$(tmux display -p -t \"$TMUX_PANE\" '#{pane_tty}' 2>/dev/null); [ -n \"$tty\" ] && printf '\\a' > \"$tty\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "language": "japanese",
  "alwaysThinkingEnabled": true,
  "theme": "dark-daltonized",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
