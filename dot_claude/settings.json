{
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tmux_info=$(tmux display-message -p '#S' 2>/dev/null); terminal-notifier -title \"Claude Code: ${tmux_info}\" -message \" コマンド実行していいですか\" -sound default "
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tmux_info=$(tmux display-message -p '#S' 2>/dev/null); terminal-notifier -title \"Claude Code: ${tmux_info}\" -message '終わったよ' -sound default"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/k-sakamoto/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "Notion@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "theme": "dark-daltonized",
  "skipAutoPermissionPrompt": true
}
